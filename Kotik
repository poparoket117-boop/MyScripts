    funLabel.TextScaled = true
    funLabel.BackgroundTransparency = 1
    funLabel.Font = Enum.Font.ComicSans
    funLabel.Parent = ContentFrame

    local function makeFunBtn(text, y, callback, color)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0.7, 0, 0.12, 0)
        btn.Position = UDim2.new(0.15, 0, y, 0)
        btn.Text = text
        btn.TextColor3 = Color3.fromRGB(255,255,255)
        btn.BackgroundColor3 = color or Color3.fromRGB(255, 100, 0)
        btn.Font = Enum.Font.ComicSans
        btn.TextScaled = true
        btn.Parent = ContentFrame
        btn.MouseButton1Click:Connect(callback)
        return btn
    end

    makeFunBtn("🎆 Фейерверк (частицы)", 0.2, function()
        local part = Instance.new("Part")
        part.Size = Vector3.new(2,2,2)
        part.Position = LocalPlayer.Character.HumanoidRootPart.Position + Vector3.new(0, 5, 0)
        part.Anchored = true
        part.Parent = workspace
        local att = Instance.new("Attachment", part)
        local emit = Instance.new("ParticleEmitter", att)
        emit.Texture = "rbxasset://textures/particles/sparkles_main.dds"
        emit.Rate = 200
        emit.Lifetime = NumberRange.new(1, 2)
        emit.SpreadAngle = Vector2.new(360, 360)
        emit.VelocityInheritance = 0
        emit.Speed = NumberRange.new(10, 30)
        emit.Color = ColorSequence.new(Color3.fromRGB(255,165,0), Color3.fromRGB(255,255,255))
        emit.Enabled = true
        wait(0.5)
        emit.Enabled = false
        wait(1)
        part:Destroy()
    end)

    makeFunBtn("🕺 Танец (анимация)", 0.35, function()
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            local anim = Instance.new("Animation")
            anim.AnimationId = "rbxassetid://5077730892" -- анимация танца
            local track = char.Humanoid:LoadAnimation(anim)
            track:Play()
            wait(3)
            track:Stop()
        end
    end, Color3.fromRGB(200, 80, 200))

    makeFunBtn("🐱 Призвать кота (меш)", 0.5, function()
        local cat = Instance.new("Part")
        cat.Size = Vector3.new(2, 2, 2)
        cat.Position = LocalPlayer.Character.HumanoidRootPart.Position + Vector3.new(0, 0, 5)
        cat.Shape = Enum.PartType.Cylinder
        cat.Color = Color3.fromRGB(255, 165, 0)
        cat.Anchored = true
        cat.Parent = workspace
        local decal = Instance.new("Decal")
        decal.Texture = "rbxassetid://6019171376" -- текстура кота
        decal.Face = Enum.NormalId.Front
        decal.Parent = cat
        wait(3)
        cat:Destroy()
    end, Color3.fromRGB(255, 200, 0))

    makeFunBtn("💥 Взрыв (эффект)", 0.65, function()
        local pos = LocalPlayer.Character.HumanoidRootPart.Position
