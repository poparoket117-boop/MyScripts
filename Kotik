        btn.TextColor3 = Color3.fromRGB(255,255,255)
        btn.BackgroundColor3 = Color3.fromRGB(255, 120, 0)
        btn.Font = Enum.Font.ComicSans
        btn.TextScaled = true
        btn.Parent = ContentFrame
        btn.MouseButton1Click:Connect(function() setSpeed(spd) end)
