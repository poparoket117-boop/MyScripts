-- Вкладка 2: Скорость (без иллюзий)
createTab("⚡ Скорость", function()
    clearContent()
    local speedLabel = Instance.new("TextLabel")
    speedLabel.Size = UDim2.new(0.8, 0, 0.15, 0)
    speedLabel.Position = UDim2.new(0.1, 0, 0, 0)
