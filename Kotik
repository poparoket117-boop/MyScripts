    -- Кнопка "Как кот" (случайная скорость)
    local catBtn = Instance.new("TextButton")
    catBtn.Size = UDim2.new(0.6, 0, 0.12, 0)
    catBtn.Position = UDim2.new(0.2, 0, 0.5, 0)
