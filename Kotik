    catBtn.TextColor3 = Color3.fromRGB(255,255,255)
    catBtn.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
    catBtn.Font = Enum.Font.ComicSans
    catBtn.TextScaled = true
